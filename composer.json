{
    "name": "erorplex/freescout-ai-assist",
    "description": "Guidance-first AI reply drafts for FreeScout.",
    "license": "MIT",
    "type": "freescout-module",
    "require": {
        "php": ">=7.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
